{
    "name": "shared/deletion",
    "description": "Deletion analysis & cascade orchestration for Doctrine entities",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "doctrine/orm": "^2.14",
        "psr/log": "^1.1 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Shared\\Deletion\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shared\\Deletion\\Tests\\": "tests/",
            "Shared\\Persistence\\": "tests/Stub/Persistence/"
        },
        "files": [
            "tests/Fixture/fixtures.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
